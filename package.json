{
  "name": "freeplay-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Freeplay monorepo with shared TypeScript packages",
  "keywords": [
    "monorepo",
    "typescript",
    "freeplay"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=18",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "pnpm -r format",
    "format:fix": "pnpm -r format:fix",
    "typecheck": "pnpm -r typecheck",
    "example:next": "pnpm --filter vercel build && pnpm --filter vercel-next-example dev",
    "example:node": "pnpm --filter vercel build && pnpm --filter vercel-node-example dev",
    "example:test-run": "pnpm --filter vercel build && pnpm --filter vercel-test-run-example start"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.9.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.2"
  },
  "pnpm": {
    "overrides": {
      "@freeplayai/vercel": "workspace:*",
      "minimatch@3": "~3.1.4",
      "minimatch@^9": "^9.0.7",
      "rollup@4": "^4.59.0",
      "axios@1": "^1.13.5",
      "glob@10": "^10.5.0",
      "jws@4": "^4.0.1",
      "qs@6": "^6.14.2",
      "ajv@6": "^6.14.0",
      "body-parser@2": "^2.2.1",
      "js-yaml@4": "^4.1.1",
      "esbuild": "^0.25.0",
      "flatted": "^3.4.2",
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "path-to-regexp": ">=8.4.0",
      "brace-expansion": ">=2.0.3"
    }
  }
}
